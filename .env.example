# =============================================================
# Silver Lady's — muhit o'zgaruvchilari shabloni
# Bu faylni nusxalab .env deb saqlang va qiymatlarni to'ldiring.
# .env faylni HECH QACHON git ga push qilmang!
# =============================================================

# --- Ma'lumotlar bazasi ---
DB_URL=jdbc:postgresql://localhost:5432/silver_lady_s_db
DB_USER=postgres
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD_HERE

# --- JWT ---
# Kamida 64 ta tasodifiy belgi: openssl rand -hex 64
JWT_SECRET=YOUR_VERY_LONG_RANDOM_SECRET_HERE_MIN_64_CHARS
JWT_ISSUER=silver_lady_s
JWT_ACCESS_MIN=120

# --- CORS ---
# Vergul bilan ajrating: https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Admin bootstrap (FAQAT birinchi deploy'da true, keyin false qiling!) ---
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@silverladys.uz
BOOTSTRAP_ADMIN_PASSWORD=YOUR_STRONG_ADMIN_PASSWORD_HERE
BOOTSTRAP_ADMIN_FULL_NAME=Main Admin

# --- JPA ---
# LOCAL dev: update (jadvallarni avtomatik yaratadi)
# PRODUCTION: validate (schema o'zgarsa xato beradi — kutilmagan migratsiyalardan saqlaydi)
DDL_AUTO=validate
SHOW_SQL=false

# --- Media (rasmlar) ---
# Rasmlar saqlanadigan papka
MEDIA_UPLOAD_DIR=uploads
# Tashqi URL (nginx orqali serve qilinganda to'g'ri domenga o'zgartiring)
MEDIA_BASE_URL=http://localhost:8080
# Bir fayl uchun max o'lcham
MEDIA_MAX_FILE_SIZE=10MB
MEDIA_MAX_REQUEST_SIZE=50MB
MEDIA_MAX_FILE_SIZE_MB=10
MEDIA_MAX_IMAGES_PER_PRODUCT=10

# --- Server ---
PORT=8080
